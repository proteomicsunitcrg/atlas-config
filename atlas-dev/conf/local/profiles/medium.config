process {
    withLabel: mascot {
        container = "${params.comet_img}"
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withLabel: comet {
        container = "${params.comet_img}"
        cpus = 5
        memory = '8 GB'
        time = '1h'
    }

    // No `container` override here on purpose: DIANN_RUN sets its own container
    // per-method dynamically (from diann_methods_config.yaml, e.g. diann-1.9.2.img
    // for QCD1/QCD2 vs diann-2.3.2.img for MK/NK/...). A config-level container
    // here would win over that and force every diann-labelled process onto a
    // single fixed image (this broke QCD1, which silently ran under diann-2.3.2.img).
    withLabel: diann {
        cpus = 3
        memory = '5 GB'
        time = '1h'
    }

    withLabel: diann_bruker {
        cpus = 40
        memory = '10 GB'
        time = '1h'
    }

    withLabel: fragpipe {
        container = "${params.fp_img}"
        cpus = 5
        memory = '10 GB'
        time = '1h'
    }
}
