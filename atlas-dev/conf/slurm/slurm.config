includeConfig '../shared.config'

executor {
    pollInterval = '30 sec'
}

process {

    executor = 'slurm'
    cache = 'lenient'
    queue = 'genoa64'
    cpus = '1'
    memory = '10G'
    time = '6h'
    scratch = false
    errorStrategy = 'ignore'

    clusterOptions = '--qos=core'

    withLabel: big_mem {
        memory = '60G' 
        time = '12h'   
    }

    withLabel: big_cpus {
        cpus = 8
        time = '6h'
        memory = '20G'
    }

    withLabel: little_comp {
        maxForks = 1
        maxRetries = 3
        errorStrategy = { task.attempt < 3 ? 'retry' : 'ignore' }
    }

    withLabel: local {
        executor = "local"
    }

    withLabel: thermoconvert {
        container = "${params.trfp_img}"
        cpus = 1
        
        // Dynamic memory based on filename pattern (tag)
        memory = { 
            def filename = task.tag ?: ''
            def pattern = filename.find(/\d+([A-Z]{2,3})\d+/) ? 
                        (filename =~ /\d+([A-Z]{2,3})\d+/)[0][1] : 'UNKNOWN'
            
            def baseMem = (pattern == 'QCD1') ? 4.GB :
                        (pattern == 'QCD2') ? 8.GB : 32.GB
            
            task.attempt == 1 ? baseMem : 
            task.attempt == 2 ? baseMem * 2 : baseMem * 3
        }
        
        // Dynamic time based on filename pattern
        time = {
            def filename = task.tag ?: ''
            def pattern = filename.find(/\d+([A-Z]{2,3})\d+/) ? 
                        (filename =~ /\d+([A-Z]{2,3})\d+/)[0][1] : 'UNKNOWN'
            
            (pattern =~ /QCD/) ? '45m' : '2h'
        }
        
        errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'terminate' } 
        maxRetries = 2  
    }

    withLabel: openms {
        container = "${params.comet_img}"
        time = '6h'
        memory = '9G'
    }

    withLabel: ffm {
        container = "${params.comet_img}"
        time = '6h'
        memory = '9G'
    }

    withLabel: clitools {
        container = "${params.clitools_img}"
        time = '1h'
        memory = '4G'
    }

    
    withLabel: rawrr {
        container = params.rawrr_img
        time = '1h'
        memory = '32G'
    }

}
